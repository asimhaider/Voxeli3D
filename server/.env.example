# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Admin authentication. Use two different long, random values.
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Supabase (server-only). Never expose the service-role key in Vercel or the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=reference-images
SUPABASE_CATALOGUE_BUCKET=catalogue-images

# Required only for automatic Meshy 3D previews.
MESHY_API_KEY=

# Resend transactional email. This uses HTTPS and works on Render Free.
RESEND_API_KEY=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=Voxelis <notifications@yourdomain.com>
