# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Meshy (2D-to-3D generation) — add this later
MESHY_API_KEY=

# Email notifications — optional. If left blank, requests are only
# saved to server/data/*.json and NOT emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
