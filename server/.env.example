# Server
PORT=5000
CORS_ORIGIN=http://localhost:5173

# Password used by the /admin interface to protect submissions and previews.
# Use a long, unique value in server/.env or your hosting provider's environment settings.
ADMIN_PASSWORD=

# Required only for automatic Meshy 3D previews.
MESHY_API_KEY=

# Public HTTPS address of this backend. Meshy must be able to fetch /uploads from it.
PUBLIC_API_URL=https://voxelis-backend.onrender.com 

# Optional email notification settings.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
NOTIFY_EMAIL_TO=
NOTIFY_EMAIL_FROM=
