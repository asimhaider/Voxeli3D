# Public URL of the deployed Express backend. Do not include a trailing slash.
# Example: VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=

# Digits only: country code followed by the WhatsApp Business number.
# Example for India: VITE_WHATSAPP_NUMBER=919876543210
VITE_WHATSAPP_NUMBER=

# Public contact links shown in the website contact strip.
# The phone value falls back to the WhatsApp number when blank.
VITE_CONTACT_PHONE=
VITE_CONTACT_EMAIL=contact@voxelis3d.in
